# Anthropic API key — used to power the ordering agent
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Anthropic model to use (optional, defaults to claude-opus-4-5)
# Use a smaller model like claude-3-5-haiku-20241022 to reduce cost.
# ANTHROPIC_MODEL=claude-opus-4-5

# Swiggy OAuth access token
# Obtain via: https://mcp.swiggy.com/builders/docs/start/authenticate.md
# Token lifetime: 5 days. Re-run OAuth flow when expired.
SWIGGY_ACCESS_TOKEN=your_swiggy_access_token_here

# Swiggy MCP server URLs (defaults shown — only change if Swiggy updates them)
SWIGGY_FOOD_MCP_URL=https://mcp.swiggy.com/food
